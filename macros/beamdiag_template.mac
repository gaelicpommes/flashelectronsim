# =========================
# beamdiag_template.mac
# One run produces:
#  - PDD (1D) in water along CAX
#  - Exit plane 2D dose (water surface slab)
#  - Exit plane 2D fluence
# =========================

/control/verbose 1
/run/verbose 0
/event/verbose 0
/tracking/verbose 0

# Applicator ID selection in cm (allowed: 10, 5, 2)
# You can also set: export FLASH_APPLICATOR_CM=10|5|2
/flash/setApplicatorIDcm 10
# Optional batch replacement token:
# /flash/setApplicatorIDcm APPLICATOR_CM

# Init
/run/initialize

# Source (GPS commands require actions to be initialized)
/control/execute ../macros/conv9source.mac
# Optional batch replacement token:
# /control/execute SOURCE_MAC

# -------------------------
# (A) PDD mesh (1D along Z)
# -------------------------
/score/create/boxMesh pdd1D
/score/mesh/boxSize 50 50 40 mm
/score/mesh/nBin    1 1 160
/score/mesh/translate/xyz 0 0 544.9 mm
/score/quantity/doseDeposit pddDose
/score/close

# -------------------------
# (B) Exit plane 2D mesh (water surface slab)
# -------------------------
/score/create/boxMesh exit2D
/score/mesh/boxSize 80 80 0.25 mm  #+/-80mm(160x160mm)
/score/mesh/nBin    80 80 1   # 120 mm / 60 = 2 mm pixels
/score/mesh/translate/xyz 0 0 504.85 mm
/score/quantity/doseDeposit exitDose
/score/quantity/cellFlux    exitfluence
/score/close

# Run (default runnable line)
/run/beamOn 10000
# Optional batch replacement token:
# /run/beamOn BEAMON

# Dump all outputs
/score/dumpQuantityToFile pdd1D  pddDose   PDD_TXT
/score/dumpQuantityToFile exit2D exitDose   EXIT_DOSE_TXT
/score/dumpQuantityToFile exit2D exitfluence EXIT_FLUENCE_TXT

