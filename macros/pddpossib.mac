# =========================
# pddpossib.mac
# One run produces:
#  - PDD (1D) in water along CAX
#  - Exit plane 2D dose (water surface slab)
#  - Exit plane 2D fluence
# =========================

/control/verbose 1
/run/verbose 0
/event/verbose 0
/tracking/verbose 0

# Applicator ID selection in cm (allowed: 10, 5, 2)
# You can also set: export FLASH_APPLICATOR_CM=10|5|2
# Optional (requires binary with /flash messenger support):
#/flash/setApplicatorIDcm 10
# Optional batch replacement token:
/flash/setApplicatorIDcm APPLICATOR_CM

# Init
/run/initialize

# Source (GPS commands require acti ons to be initialized)
#/control/execute ../macros/sourcepossib.mac
# Optional batch replacement token:
/control/execute SOURCE_MAC

# -------------------------
# (A) PDD mesh (1D along Z)
# -------------------------
/score/create/boxMesh pdd1D
/score/mesh/boxSize 1 1 40 mm
/score/mesh/nBin    1 1 160
/score/mesh/translate/xyz 0 0 544.9 mm
/score/quantity/doseDeposit pddDose
/score/close



# -------------------------
# (C) Lateral profile at dmax depth (2D slab)
# -------------------------
/score/create/boxMesh latDmax2D
/score/mesh/boxSize 75 75 0.25 mm
/score/mesh/nBin    150 150 1
/score/mesh/translate/xyz 0 0 518.9 mm
/score/quantity/doseDeposit latDmaxDose
/score/close

# -------------------------
# (D) Lateral profile at R50 depth (2D slab)
# -------------------------
/score/create/boxMesh latR50_2D
/score/mesh/boxSize 75 75 0.25 mm
/score/mesh/nBin    150 150 1
/score/mesh/translate/xyz 0 0 538.3 mm
/score/quantity/doseDeposit latR50Dose
/score/close

# -------------------------
# (E) Lateral profile at mid-depth (2D slab)
# -------------------------
/score/create/boxMesh latMid2D
/score/mesh/boxSize 75 75 0.25 mm
/score/mesh/nBin    150 150 1
/score/mesh/translate/xyz 0 0 528.6 mm
/score/quantity/doseDeposit latMidDose
/score/close

# Run
/run/beamOn BEAMON

# Dump outputs
/score/dumpQuantityToFile pdd1D     pddDose     PDD_TXT
/score/dumpQuantityToFile latDmax2D latDmaxDose LAT_DMAX_DOSE_TXT
/score/dumpQuantityToFile latR50_2D latR50Dose  LAT_R50_DOSE_TXT
/score/dumpQuantityToFile latMid2D  latMidDose  LAT_MID_DOSE_TXT



